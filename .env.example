# X Sign in. Do not commit real values.
X_CLIENT_ID=
X_CLIENT_SECRET=
X_OAUTH_SCOPE=users.read tweet.read
AUTH_SESSION_SECRET=

# Optional local-only fallback for playtesting without real X credentials.
# This only works on localhost and must stay off in production.
DEV_AUTH_BYPASS=0
DEV_AUTH_USERNAME=RegionsPlay7941
DEV_AUTH_USER_ID=local-dev

# Local callback URL. Add the same URL in X Developer Portal callback settings.
X_CALLBACK_URL=http://localhost:8787/api/auth/x/callback
CLIENT_ORIGIN=http://127.0.0.1:5173
VITE_GAME_SERVER_URL=http://localhost:8787

# Local client against the production backend:
# pnpm dev:remote
# VITE_GAME_SERVER_URL=https://renaiss-game.zeabur.app

# Production public origin and local dev origins allowed by the server CORS policy.
SERVER_PUBLIC_ORIGIN=https://renaiss-game.zeabur.app
LOCAL_DEV_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Optional. Production defaults to the R2 CDN URL in code and Docker.
VITE_STATIC_ASSET_BASE_URL=https://pub-043b57dfe27c4f7e9a469bbc5d7f33dc.r2.dev/renaiss-game

# Set to 1 only behind HTTPS in production.
AUTH_COOKIE_SECURE=0

# Keep Lax for local same-origin dev. Set to none on Zeabur only when local
# frontends need to use the production backend session cookie.
AUTH_COOKIE_SAME_SITE=lax

# Zeabur production data. Mount a persistent Volume with id "data" at /data.
RENAISS_GAME_DATA_DIR=/data/renaiss-game
RENAISS_RPG_DB_PATH=/data/renaiss-game/rpg-profile.sqlite
